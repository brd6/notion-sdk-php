# Notion integration token
NOTION_TOKEN=

# Database id to inspect (must be shared with the integration)
NOTION_DATABASE_ID=

# Optional: explicit data source id. If empty, the script uses the first data source from the database response.
NOTION_DATA_SOURCE_ID=

# Set to 1 to run create/update calls (writes). Default is read-only mode.
NOTION_RUN_WRITES=0
